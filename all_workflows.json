","type":"n8n-nodes-base.webhook","typeVersion":1.1,"position":[224,352],"webhookId":"evolution-webhook-fastgram"},{"parameters":{"conditions":{"boolean":[{"value1":"={{ $json.body.data.key.fromMe }}"}]}},"id":"e4f5a3b2-7a8d-4c5e-b9f0-8a7b6c5d4e3f","name":"Ignorar Mensagens Próprias","type":"n8n-nodes-base.if","typeVersion":1,"position":[400,352]},{"parameters":{"promptType":"define","text":"=O usuário enviou a seguinte mensagem no WhatsApp:\n\n{{ $json.body.data.message.conversation || $json.body.data.message.extendedTextMessage.text || '' }}\n\nCelular: {{ $json.body.sender }}\n\n/no_think","options":{"systemMessage":"Voce eh o assistente da FastGram, plataforma de compra de seguidores para Instagram.\nRegras:\n1. Responda SEMPRE em portugues brasileiro, de forma curta e educada.\n2. Se o cliente perguntar sobre pedido e fornecer um ID, use a ferramenta ConsultarPedido.\n3. Se o cliente perguntar precos: 1000 seguidores = R$24,90.\n4. Nao invente informacoes. Se nao souber, peca mais detalhes.\n5. NUNCA escreva seus pensamentos ou raciocinio. Responda APENAS a mensagem final para o cliente.\n6. NUNCA use ingles. Tudo em portugues.\n/no_think"}},"id":"e285a210-67c4-406a-8d30-b30a597db244","name":"AI Agent","type":"@n8n/n8n-nodes-langchain.agent","typeVersion":1.7,"position":[640,320]},{"parameters":{"model":"fastgram-bot","options":{"temperature":0.4,"keepAlive":"10m","numCtx":2048}},"id":"1d8eb6d4-839f-4dbd-bedc-bd940dcf906c","name":"Ollama Chat Model","type":"@n8n/n8n-nodes-langchain.lmChatOllama","typeVersion":1,"position":[640,544],"credentials":{"ollamaApi":{"id":"ollama-fastgram","name":"Ollama API"}}},{"parameters":{"sessionIdType":"customKey","sessionKey":"={{ $('Webhook Evolution API').item.json.body.sender }}","contextWindowLength":10},"id":"memory-window-node","name":"Window Buffer Memory","type":"@n8n/n8n-nodes-langchain.memoryBufferWindow","typeVersion":1.2,"position":[480,544]},{"parameters":{"toolDescription":"Consultar o status de um pedido pelo seu ID. Retorna informações como status de pagamento, nome do cliente, perfil do Instagram e contagem de seguidores.","url":"https://fastgram.com.br/api/agent/orders/{orderId}","placeholderDefinitions":{"values":[{"name":"orderId","description":"O ID do pedido para consultar o status","type":"string"}]}},"id":"tool-consultar-pedido","name":"ConsultarPedido","type":"@n8n/n8n-nodes-langchain.toolHttpRequest","typeVersion":1.1,"position":[864,544]},{"parameters":{"method":"POST","url":"=https://zap.fastgram.com.br/message/sendText/{{ $json.instance }}","sendHeaders":true,"headerParameters":{"parameters":[{"name":"apikey","value":"B4K1L3V7H8F9X2P5R6M4N1C0Z9Y8W7Q"},{"name":"Content-Type","value":"application/json"}]},"sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify({ \"number\": $json.targetNumber, \"textMessage\": { \"text\": $json.output } }) }}","options":{}},"id":"b3e0c090-cc5b-43de-b82b-c8c3e6dc2af4","name":"Enviar Resposta WhatsApp","type":"n8n-nodes-base.httpRequest","typeVersion":4.1,"position":[1104,320]},{"parameters":{"url":"=http://172.17.0.1:3847/resolve-lid?lid={{ $('Webhook Evolution API').item.json.body.data.key.remoteJid.replace('@lid', '').replace('@s.whatsapp.net', '') }}","options":{"response":{"response":{"responseFormat":"json"}}}},"id":"resolver-http-node","name":"Resolver LID","type":"n8n-nodes-base.httpRequest","typeVersion":4.1,"position":[784,128]},{"parameters":{"jsCode":"// Preparar Resposta: limpar output + resolver numero\nconst webhookData = $('Webhook Evolution API').first().json;\nconst aiRaw = $('AI Agent').first().json.output || '';\nconst resolverData = $('Resolver LID').first().json;\n\n// === LIMPAR OUTPUT ===\nlet output = aiRaw;\n\n// Remove <think>...</think> blocks\noutput = output.replace(/<think>[\\s\\S]*?<\\/think>/g, '').trim();\n\n// FILTER: Keep ONLY lines with Portuguese accented characters\n// Portuguese always has àáâãéêíóôõúç, English reasoning never does\nconst lines = output.split('\\n');\nconst ptLines = lines.filter(l => {\n  const t = l.trim();\n  if (!t) return false;\n  return /[\\u00C0-\\u00FF]/.test(t);\n});\n\nif (ptLines.length > 0) {\n  output = ptLines.join('\\n').trim();\n} else {\n  // Fallback: no accented lines found\n  const priceMatch = aiRaw.match(/R\\$\\s*[\\d,.]+/);\n  if (priceMatch) {\n    output = 'O preço de 1000 seguidores é ' + priceMatch[0] + '. Posso ajudar com mais alguma coisa?';\n  } else {\n    output = 'Olá! Sou o assistente FastGram. Como posso te ajudar?';\n  }\n}\n\n// === RESOLVER NUMERO ===\nconst remoteJid = webhookData.body?.data?.key?.remoteJid || '';\nconst instance = webhookData.body?.instance || 'FastGram_Bot';\nlet targetNumber = remoteJid.replace('@s.whatsapp.net', '').replace('@lid', '');\nif (resolverData.resolved && resolverData.phone) {\n  targetNumber = resolverData.phone;\n}\n\nreturn [{ json: { targetNumber, output, instance } }];"},"id":"preparar-resposta-node","name":"Preparar Resposta","type":"n8n-nodes-base.code","typeVersion":2,"position":[912,320]}],"connections":{"Webhook Evolution API":{"main":[[{"node":"Ignorar Mensagens Próprias","type":"main","index":0}]]},"Ignorar Mensagens Próprias":{"main":[[{"node":"AI Agent","type":"main","index":0}]]},"AI Agent":{"main":[[{"node":"Resolver LID","type":"main","index":0}]]},"ConsultarPedido":{"ai_tool":[[{"node":"AI Agent","type":"ai_tool","index":0}]]},"Window Buffer Memory":{"ai_memory":[[{"node":"AI Agent","type":"ai_memory","index":0}]]},"Ollama Chat Model":{"ai_languageModel":[[{"node":"AI Agent","type":"ai_languageModel","index":0}]]},"Resolver LID":{"main":[[{"node":"Preparar Resposta","type":"main","index":0}]]},"Preparar Resposta":{"main":[[{"node":"Enviar Resposta WhatsApp","type":"main","index":0}]]}},"settings":{"executionOrder":"v1","binaryMode":"separate"},"staticData":null,"meta":null,"pinData":{},"versionId":"0af84a34-3b78-4bec-823c-252e71485fd8","activeVersionId":"077c30f2-74df-45c8-aeb9-3925d9033e39","versionCounter":101,"triggerCount":1,"tags"