puts "Executando Certbot na VPS..."
spawn ssh -o StrictHostKeyChecking=no root@$ip "apt-get update && apt-get install -y python3-certbot-nginx && certbot --nginx -d ene8ene.fastgram.com.br --non-interactive --agree-tos -m alaikke@gmail.com"
